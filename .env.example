# ==========================================
# Backend Configuration (Node.js/Express)
# ==========================================

# Port for the backend server to run on
PORT=5000

# PostgreSQL Connection String (relational database only)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres:password123@localhost:5432/spreetail_expenses?schema=public"

# Secret key for JWT session tokens and encryption (use a strong random value in production)
JWT_SECRET="spreetail_jwt_secret_key_123_abc_xyz"

# Mode environment (development or production)
NODE_ENV=development

# ==========================================
# Frontend Configuration (React/Vite)
# ==========================================

# Base URL pointing to the Express backend API
VITE_API_URL="http://localhost:5000/api"
